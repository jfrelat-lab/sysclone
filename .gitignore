# Node.js dependencies
node_modules/

# macOS system files
.DS_Store

# --- Agentic Workflow & Personal Intellectual Property ---
# Exclude artifacts, agent memories, and internal code reviews 
# to protect proprietary development methodology.
artifacts/

# --- Private ROM Drafts ---
# Ignore all MS-DOS Basic files prefixed with an underscore
examples/_*.bas
examples/lab/

# --- External Compatibility Tests (QB45 / DOSBox) ---
# Ignore binary and support files extracted from legacy QB45 environments
examples/*.EXE
examples/*.exe
examples/*.COM
examples/*.LIB
examples/*.QLB
examples/*.HLP
examples/*.INI
examples/*.PIF
examples/*.BI

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test and coverage (optional but recommended)
.npm
.eslintcache